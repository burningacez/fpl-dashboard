# FPL Dashboard Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED FOR PRODUCTION
# =============================================================================

# Admin password for the admin panel (CHANGE THIS!)
ADMIN_PASSWORD=your-secure-password-here

# Upstash Redis credentials (for persistent storage)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# =============================================================================
# OPTIONAL
# =============================================================================

# Server port (default: 3001, Render sets this automatically)
# PORT=3001

# League ID — EMERGENCY OVERRIDE ONLY. The league id normally comes from the
# active season's entry in src/lib/season-config.ts.
# LEAGUE_ID=619028

# Current season — boot-time FALLBACK only (default: 2025-26). Once the admin
# "Start new season" action has run, the active season lives in Redis
# ('active-season') and wins over this value. Season-specific rules/prizes
# live in src/lib/season-config.ts, keyed by season id.
# CURRENT_SEASON=2025-26

# Email alerts for errors (optional)
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password
# ALERT_EMAIL=alerts@example.com

# =============================================================================
# SET BY DEPLOYMENT PLATFORM
# =============================================================================

# NODE_ENV is typically set by your deployment platform
# NODE_ENV=production
